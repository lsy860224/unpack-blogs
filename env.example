# ====================================
# unpack-blogs 환경변수
# ====================================
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요
# cp .env.example .env.local
#
# 참고: 사이트별 환경변수는 Vercel 프로젝트에서 각각 설정합니다.
# 로컬 개발 시에는 작업 중인 사이트의 변수만 설정하면 됩니다.

# --- AIGrit (aigrit.dev) ---
# https://analytics.google.com → 관리 → 데이터 스트림
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# https://adsense.google.com → 계정 → 게시자 ID
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# https://giscus.app → 설정 후 발급
NEXT_PUBLIC_GISCUS_REPO=username/aigrit-comments
NEXT_PUBLIC_GISCUS_REPO_ID=R_XXXXXXXXXX
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_XXXXXXXXXX

# 사이트 URL (배포 환경에 맞게)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- babipanote (babipanote.com) ---
# babipanote 로컬 개발 시 위 변수들을 babipanote용으로 교체
# Vercel에서는 프로젝트별로 별도 설정하므로 충돌 없음
