# ============================================
# AIGrit 환경변수
# ============================================
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요
# cp .env.example .env.local
# ⚠️ .env.local은 절대 Git에 커밋하지 마세요

# --- Google Analytics 4 ---
# 발급: https://analytics.google.com → 관리 → 데이터 스트림 → 측정 ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Google AdSense ---
# 발급: https://adsense.google.com → 계정 → Publisher ID
# 애드센스 승인 전에는 빈 값으로 두세요
NEXT_PUBLIC_ADSENSE_ID=

# --- Giscus (댓글) ---
# 설정: https://giscus.app → 저장소 + 카테고리 선택 → 코드 생성
NEXT_PUBLIC_GISCUS_REPO=lsy860224/aigrit
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# --- 사이트 URL ---
# 로컬: http://localhost:3000
# 프로덕션: https://aigrit.dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000
