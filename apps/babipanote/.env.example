# ============================================
# babipanote 환경변수
# ============================================
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요
# cp .env.example .env.local
# ⚠️ .env.local은 절대 Git에 커밋하지 마세요
# ⚠️ babipanote는 광고 비연동 — AdSense 변수 없음

# --- Google Analytics 4 ---
# AIGrit과 별도 측정 ID 발급 필요
# 발급: https://analytics.google.com → 관리 → 데이터 스트림 → 측정 ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Giscus (댓글) ---
# 1. https://github.com/lsy860224/babipanote-comments (public) — Settings → Discussions 활성화
# 2. https://github.com/apps/giscus 설치
# 3. https://giscus.app → 저장소 lsy860224/babipanote-comments 입력 → data-repo-id, data-category-id 복사
NEXT_PUBLIC_GISCUS_REPO=lsy860224/babipanote-comments
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# --- 사이트 URL ---
# 로컬: http://localhost:3000
# 프로덕션: https://babipanote.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
