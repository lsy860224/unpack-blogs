{
  "name": "@unpack/blog-core",
  "version": "0.1.0",
  "private": true,
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./lib/*": {
      "types": "./lib/*.ts",
      "default": "./lib/*.ts"
    },
    "./components/blog/*": "./components/blog/*",
    "./components/mdx/*": "./components/mdx/*",
    "./components/ads/*": "./components/ads/*",
    "./components/analytics/*": "./components/analytics/*",
    "./config/*": "./config/*",
    "./contexts/*": {
      "types": "./contexts/*.tsx",
      "default": "./contexts/*.tsx"
    },
    "./types/*": {
      "types": "./types/*.ts",
      "default": "./types/*.ts"
    },
    "./hooks/*": {
      "types": "./hooks/*.ts",
      "default": "./hooks/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "next-mdx-remote": "^6.0.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
